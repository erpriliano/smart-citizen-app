{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@smart-citizen/identity-contracts": ["./libs/identity/contracts/src/index.ts"],
      "@smart-citizen/platform-contracts": ["./libs/platform/contracts/src/index.ts"],
      "@smart-citizen/community-contracts": ["./libs/community/contracts/src/index.ts"],
      "@smart-citizen/residency-contracts": ["./libs/residency/contracts/src/index.ts"],
      "@smart-citizen/finance-contracts": ["./libs/finance/contracts/src/index.ts"],
      "@smart-citizen/publication-contracts": ["./libs/publication/contracts/src/index.ts"],
      "@smart-citizen/identity-api": ["./libs/identity/api/src/index.ts"],
      "@smart-citizen/platform-api": ["./libs/platform/api/src/index.ts"],
      "@smart-citizen/community-api": ["./libs/community/api/src/index.ts"],
      "@smart-citizen/residency-api": ["./libs/residency/api/src/index.ts"],
      "@smart-citizen/finance-api": ["./libs/finance/api/src/index.ts"],
      "@smart-citizen/publication-api": ["./libs/publication/api/src/index.ts"],
      "@smart-citizen/audit-api": ["./libs/audit/api/src/index.ts"],
      "@smart-citizen/identity-web": ["./libs/identity/web/src/index.ts"],
      "@smart-citizen/platform-web": ["./libs/platform/web/src/index.ts"],
      "@smart-citizen/community-web": ["./libs/community/web/src/index.ts"],
      "@smart-citizen/residency-web": ["./libs/residency/web/src/index.ts"],
      "@smart-citizen/finance-web": ["./libs/finance/web/src/index.ts"],
      "@smart-citizen/publication-web": ["./libs/publication/web/src/index.ts"],
      "@smart-citizen/shared-ui": ["./libs/shared/ui/src/index.ts"],
      "@smart-citizen/shared-ui/*": ["./libs/shared/ui/src/*"],
      "@smart-citizen/shared-database": ["./libs/shared/database/src/index.ts"],
      "@smart-citizen/shared-testing": ["./libs/shared/testing/src/index.ts"],
      "@smart-citizen/shared-configuration": ["./libs/shared/configuration/src/index.ts"],
      "@smart-citizen/shared-http-client": ["./libs/shared/http-client/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
